# Auto detect text files and perform LF normalization
* text=auto

# Go source
*.go text diff=golang

# TypeScript
*.ts text diff=typescript
*.tsx text diff=typescript

# SQL
*.sql text

# Shell scripts
*.sh text eol=lf

# Batch files
*.bat text eol=crlf
*.cmd text eol=crlf

# HTML, CSS, JS, JSON
*.html text
*.css text
*.scss text
*.js text
*.json text
*.yml text
*.yaml text
*.xml text
*.md text

# Images
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg text

# Fonts
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
